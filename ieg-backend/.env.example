# IEG Backend — Environment Variables
# Copy to .env and fill in your values

NODE_ENV=development
PORT=5000

# E2E tests (optional overrides)
# API_HOST=127.0.0.1
# API_BASE_URL=http://127.0.0.1:5000

# MongoDB Atlas (recommended for production)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=ieg_platform

# Local development fallback:
# MONGO_URI=mongodb://localhost:27017/ieg_platform

# JWT (use long random strings in production)
JWT_ACCESS_SECRET=ieg_dev_access_secret_32_chars_min_ok
JWT_REFRESH_SECRET=ieg_dev_refresh_secret_32_chars_min
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS — must match your frontend dev server
CLIENT_URL=http://localhost:5173

# Email (optional — emails are logged to console if not configured)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="IEG Platform <noreply@iegplatform.com>"

# Cloudinary — image & document cloud storage
# Without these, files are saved to the local uploads/ directory instead
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Platform Fee Percentage
PLATFORM_FEE_PERCENT=2.5
